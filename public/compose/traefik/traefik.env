### Image Information
# REPO=traefik # Not used
NAME=traefik
TAG=3.1.2

### APP Directory
DIR_TRAEFIK=/etc/traefik

### Files
SSL_CERT=${DIR_SSL}/acme.json

### IP List
IP_INTERNAL_TRAEFIK=${IP_INTERNAL_BASE}2
IP_PRIVATE_TRAEFIK=${IP_PRIVATE_BASE}2
IP_PUBLIC_TRAEFIK=${IP_PUBLIC_BASE}2

### Ports List
PORT_TRAEFIK_HTTP=80
PORT_TRAEFIK_HTTPS=443
PORT_TRAEFIK_DASH=8080
PORT_TRAEFIK_PING=8081

### Command Variables
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_MAX_AGE=7
LOG_BUFFER=100
STATUS_CODES=200-299,300-399
CERT_RESOLVER=dns-cloudflare
DNS_CHALLENGE_1=1.1.1.1:53
DNS_CHALLENGE_2=1.0.0.1:53

### Cloudflare Information
CF_IPS_1=103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,104.24.0.0/14,104.16.0.0/13,108.162.192.0/18,
CF_IPS_2=131.0.72.0/22,141.101.64.0/18,162.158.0.0/15,172.64.0.0/13,173.245.48.0/20,188.114.96.0/20,
CF_IPS_3=190.93.240.0/20,197.234.240.0/22,198.41.128.0/17
CF_IPS=${CF_IPS_1}${CF_IPS_2}${CF_IPS_3}

### Secret Files
CF_API_EMAIL_FILE=${VOL_CONTAINER_SECRETS}/cf_api_email.secret
HTPASSWD_FILE=${VOL_CONTAINER_SECRETS}/basic_auth_credentials
CF_DNS_API_TOKEN_FILE=${VOL_CONTAINER_SECRETS}/cf_dns_api_token

### Re-usable Variables
TR_RTR=traefik.http.routers.traefik-rtr
TR_CR=traefik.certificatesresolvers.${CERT_RESOLVER}.acme
TR_CR_DNS=certificatesresolvers.${CERT_RESOLVER}.acme
TR_EP_WEB=entrypoints.web.http.redirections.entrypoint