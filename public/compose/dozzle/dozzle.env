### Image Information
REPO=amir20
NAME=dozzle
TAG=v8.4.3

### IP List
IP_INTERNAL_DOZZLE=${IP_INTERNAL_BASE}9
IP_PUBLIC_DOZZLE=${IP_PUBLIC_BASE}9

### Ports List
PORT_DOZZLE_HTTP=8082

### Container Variables
DIR_CONFIG=/data
DOZZLE_LEVEL=info
DOZZLE_FILTER="status=running"

### Re-usable Variables
TR_RTR=traefik.http.routers.dozzle-rtr
TR_SVC=traefik.http.services.dozzle-svc