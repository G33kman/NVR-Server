### Image Information
REPO=portainer
NAME=portainer-ce
TAG=2.20.3-alpine

### IP List
IP_INTERNAL_PORTAINER=${IP_INTERNAL_BASE}3
IP_PUBLIC_PORTAINER=${IP_PUBLIC_BASE}3

### Ports List
PORT_PORTAINER_HTTP=9000
PORT_PORTAINER_HTTPS=9443

### Container Variables
DIR_CONFIG=/data

### Re-usable Variables
TR_RTR=traefik.http.routers.portainer-rtr
TR_SVC=traefik.http.services.portainer-svc