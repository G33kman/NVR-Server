### Image Information
REPO=linuxserver
NAME=socket-proxy
TAG=1.26.2

### IP List
IP_INTERNAL_SOCKET=${IP_INTERNAL_BASE}30

### Ports List
PORT_SOCKET_PROXY=2375

### Container Variables
LOG_LEVEL=info #debug, info, notice, warning, error, alert, emerg
DIR_CONFIG=/run

### Parameters # 0 to revoke # 1 to grant
ALLOW_START=1
ALLOW_STOP=1
ALLOW_RESTARTS=0
AUTH=0
BUILD=0
COMMIT=0
CONFIGS=0
CONTAINERS=1 # Traefik, Portainer, etc..
DISABLE_IPV6=0
DISTRIBUTION=0
EVENTS=1
EXEC=1
IMAGES=1 # Portainer
INFO=1 # Portainer
NETWORKS=1 # Portainer
NODES=0
PING=1
POST=0 # 1 for Watchtower
PLUGINS=0
SECRETS=0
SERVICES=1 # Portainer
SESSION=0
SWARM=0
SYSTEM=0
TASKS=1 # Portainer
VERSION=1
VOLUMES=1 # Portainer