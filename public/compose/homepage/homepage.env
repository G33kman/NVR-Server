### Image Information
REPO=ghcr.io/gethomepage
NAME=homepage
TAG=latest # No version tag

## System Variables
TZ=${SYS_TZ}
PUID=${SYS_PUID}
PGID=${SYS_PGID}

### IP List
IP_INTERNAL_HOMEPAGE=${IP_INTERNAL_BASE}4
IP_PUBLIC_HOMEPAGE=${IP_PUBLIC_BASE}4

### Ports List
PORT_HOMEPAGE_HTTP=3000

## Container Variables
NODE_ENV=development
DIR_CONFIG=/app/config

### Re-usable Variables
TR_RTR=traefik.http.routers.homepage-rtr
TR_SVC=traefik.http.services.homepage-svc